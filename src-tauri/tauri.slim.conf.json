{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VelocityDL",
  "version": "0.1.0-beta.1",
  "identifier": "com.velocitydl.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/build.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VelocityDL",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../chromium-extension/": "chromium-extension",
      "target/release/vdl_native_host.exe": "native-host/vdl_native_host.exe"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "clipboard-manager": null,
    "dialog": null,
    "fs": null
  }
}
