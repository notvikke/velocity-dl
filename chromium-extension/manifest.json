{
  "manifest_version": 3,
  "name": "VelocityDL Bridge",
  "version": "0.1.0",
  "description": "Send browser downloads to VelocityDL via native messaging.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "alarms",
    "downloads",
    "storage",
    "nativeMessaging",
    "contextMenus",
    "tabs",
    "webRequest",
    "webNavigation",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["scan-overlay.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "VelocityDL Bridge",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    },
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon-32.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
